# Upstash Redis — for premium email storage, rate limiting, and renewal tracking
# Get these from https://console.upstash.com/
KV_REST_API_URL=https://your-redis-url.upstash.io
KV_REST_API_TOKEN=your_upstash_token_here

# Dodo Payments — webhook secret for signature verification
# Get this from your Dodo Payments dashboard → Webhooks
DODO_WEBHOOK_SECRET=your_dodo_webhook_secret_here

# Dodo Payments — REST API key for programmatic subscription cancellation
# Get this from your Dodo Payments dashboard → API Keys
DODO_API_KEY=your_dodo_api_key_here

# Dodo Payments — public checkout URLs (exposed to browser)
NEXT_PUBLIC_DODO_MONTHLY_URL=https://checkout.dodopayments.com/buy/your_monthly_link
NEXT_PUBLIC_DODO_YEARLY_URL=https://checkout.dodopayments.com/buy/your_yearly_link

# Public app base URL (used in reminder email cancel links)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Resend API key for transactional emails (renewal reminders)
# Get this from https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# From address for reminder emails
EMAIL_FROM=noreply@your-domain.com

# Secret token to protect the /api/premium/remind cron endpoint
# Pass as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=a_long_random_secret_string
